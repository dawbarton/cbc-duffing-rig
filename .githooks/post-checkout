#!/usr/bin/env bash
#
# post-checkout hook: branch-keyed data store
# ---------------------------------------------
# Purpose: keep the repo's untracked data folders (data/ results/ generated/)
# isolated per git branch. On every branch checkout, this hook repoints those
# three paths (as symlinks) at the current branch's bucket inside an external
# store, creating buckets on demand. Switching branch therefore swaps the data
# underneath the working tree without any git-tracked file changing.
#
# See docs: AGENTS.md "Data Provenance" and src/scripts/data-store/README.md
#
# Git passes three args to post-checkout: <prev-HEAD> <new-HEAD> <is-branch>.
# is-branch == 1 for a branch/switch checkout, 0 for a file checkout (which we
# ignore, since file checkouts must not disturb the data symlinks).

set -euo pipefail

is_branch_checkout="${3:-0}"
[ "$is_branch_checkout" = "1" ] || exit 0

# External store root (override via .cbc-data.env at the repo root if desired).
DATA_ROOT="/workspace/cbc-duffing-rig-data"
repo_root="$(git rev-parse --show-toplevel)"
[ -f "$repo_root/.cbc-data.env" ] && . "$repo_root/.cbc-data.env"

# Determine the current branch. On a detached HEAD, do nothing: leave the
# existing symlinks pointing at whatever branch they last tracked. This is
# deliberate — a detached HEAD is transient (notably the internal checkouts git
# performs during a rebase), and minting per-commit buckets there would both
# clutter the store and leave the symlinks pointing at an empty bucket once the
# rebase reattaches HEAD. Inspecting an old commit thus shows the current
# branch's data, which is the pragmatic choice.
branch="$(git symbolic-ref --quiet --short HEAD || true)"
if [ -z "$branch" ]; then
    exit 0
fi

bucket="$DATA_ROOT/$branch"

for name in data results generated; do
    target="$bucket/$name"
    mkdir -p "$target"
    link="$repo_root/$name"
    # Only manage the path if it is absent or already a symlink; never clobber a
    # real directory (that would risk data loss — setup-data-store.sh migrates
    # real dirs before the hook is ever relied upon).
    if [ -e "$link" ] && [ ! -L "$link" ]; then
        echo "post-checkout: '$link' is a real directory, not a symlink; leaving it untouched." >&2
        continue
    fi
    # Relative target (computed lexically, -sm) so the repo is portable: copy the
    # repo and its sibling store together, preserving their relative layout, and
    # the links resolve on any machine regardless of absolute paths.
    rel_target="$(realpath -sm --relative-to="$repo_root" "$target")"
    ln -sfn "$rel_target" "$link"
done
